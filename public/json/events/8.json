{
    "title": "Hội nghị khoa học Tim mạch Can thiệp Mekong lần II – 2026",
    "date": "2026-05-16",
    "location": "Cần Thơ",
    "content": "<script src=\"https://cdn.tailwindcss.com\"></script>\n<style>\n    #mica-program-component {\n        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\n    }\n\n    #mica-program-component .ribbon-title {\n        position: relative;\n        background: linear-gradient(to right, #1e3a8a, #be185d);\n        color: white;\n        padding: 12px 24px;\n        border-radius: 16px 16px 16px 0;\n        display: inline-block;\n        font-size: 1.25rem;\n        font-weight: 500;\n        margin-left: 16px;\n        margin-top: 24px;\n        margin-bottom: 24px;\n        box-shadow: 2px 2px 5px rgba(0,0,0,0.2);\n    }\n\n    #mica-program-component .ribbon-title::before {\n        content: '';\n        position: absolute;\n        bottom: -12px;\n        left: 0;\n        border-width: 12px 12px 0 0;\n        border-style: solid;\n        border-color: #1e3a8a transparent transparent transparent;\n    }\n\n    #mica-program-component table {\n        border-collapse: collapse;\n        width: 100%;\n    }\n    #mica-program-component th, \n    #mica-program-component td {\n        border: 1px solid #e5e7eb;\n        padding: 12px;\n        vertical-align: top;\n    }\n\n    /* --- LOGIC ĐIỀU HƯỚNG BẰNG CSS --- */\n    .mica-radio { display: none; }\n    .mica-panel { display: none; }\n\n    /* Hiển thị nội dung tương ứng khi menu được check */\n    #mica-tab-1:checked ~ .mica-layout #mica-content-1,\n    #mica-tab-2:checked ~ .mica-layout #mica-content-2,\n    #mica-tab-3:checked ~ .mica-layout #mica-content-3,\n    #mica-tab-4:checked ~ .mica-layout #mica-content-4,\n    #mica-tab-5:checked ~ .mica-layout #mica-content-5,\n    #mica-tab-6:checked ~ .mica-layout #mica-content-6,\n    #mica-tab-7:checked ~ .mica-layout #mica-content-7 {\n        display: block;\n    }\n\n    /* Đổi màu menu đang được chọn */\n    #mica-tab-1:checked ~ .mica-layout label[for=\"mica-tab-1\"],\n    #mica-tab-2:checked ~ .mica-layout label[for=\"mica-tab-2\"],\n    #mica-tab-3:checked ~ .mica-layout label[for=\"mica-tab-3\"],\n    #mica-tab-4:checked ~ .mica-layout label[for=\"mica-tab-4\"],\n    #mica-tab-5:checked ~ .mica-layout label[for=\"mica-tab-5\"],\n    #mica-tab-6:checked ~ .mica-layout label[for=\"mica-tab-6\"],\n    #mica-tab-7:checked ~ .mica-layout label[for=\"mica-tab-7\"] {\n        background: linear-gradient(90deg, #dbeafe 0%, transparent 100%);\n        font-weight: bold;\n        border-bottom: 1px solid #d1d5db;\n    }\n</style>\n\n<div id=\"mica-program-component\" class=\"flex flex-col w-full max-w-7xl h-[700px] bg-gray-100 text-gray-800 border border-gray-300 rounded-xl shadow-lg overflow-hidden relative\">\n    \n    <header class=\"bg-[#3b82f6] text-white p-4 shadow-sm z-10 flex-shrink-0\">\n        <h2 class=\"text-2xl font-normal tracking-wide pl-4 m-0\">Chương trình Khoa học</h2>\n    </header>\n\n    <!-- Các radio ẩn dùng để lưu trạng thái Tab -->\n    <input type=\"radio\" id=\"mica-tab-1\" name=\"mica-tabs\" class=\"mica-radio\" checked>\n    <input type=\"radio\" id=\"mica-tab-2\" name=\"mica-tabs\" class=\"mica-radio\">\n    <input type=\"radio\" id=\"mica-tab-3\" name=\"mica-tabs\" class=\"mica-radio\">\n    <input type=\"radio\" id=\"mica-tab-4\" name=\"mica-tabs\" class=\"mica-radio\">\n    <input type=\"radio\" id=\"mica-tab-5\" name=\"mica-tabs\" class=\"mica-radio\">\n    <input type=\"radio\" id=\"mica-tab-6\" name=\"mica-tabs\" class=\"mica-radio\">\n    <input type=\"radio\" id=\"mica-tab-7\" name=\"mica-tabs\" class=\"mica-radio\">\n\n    <div class=\"flex flex-1 overflow-hidden mica-layout\">\n        \n        <!-- Sidebar Menu -->\n        <aside class=\"w-64 bg-white border-r border-gray-300 shadow-sm flex-shrink-0 overflow-y-auto\">\n            <nav class=\"mt-6 relative\">\n                <div class=\"absolute left-2 top-0 bottom-0 w-1 bg-pink-700 rounded\"></div>\n                <ul class=\"pl-4 pr-2 m-0 list-none\">\n                    <!-- Các mục Menu là thẻ LABEL trỏ tới RADIO id -->\n                    <li><label for=\"mica-tab-1\" class=\"py-3 px-4 cursor-pointer flex justify-between items-center transition-colors text-gray-700 hover:bg-gray-50 border-b border-dashed border-gray-400\"><span class=\"text-[15px] pl-2\">Chương trình tổng quan</span><svg class=\"w-3 h-3 text-black\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path d=\"M4 4l12 6-12 6z\"></path></svg></label></li>\n                    <li><label for=\"mica-tab-2\" class=\"py-3 px-4 cursor-pointer flex justify-between items-center transition-colors text-gray-700 hover:bg-gray-50 border-b border-dashed border-gray-400\"><span class=\"text-[15px] pl-2\">Chương trình chi tiết</span><svg class=\"w-3 h-3 text-black\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path d=\"M4 4l12 6-12 6z\"></path></svg></label></li>\n                    <li><label for=\"mica-tab-3\" class=\"py-3 px-4 cursor-pointer flex justify-between items-center transition-colors text-gray-700 hover:bg-gray-50 border-b border-dashed border-gray-400\"><span class=\"text-[15px] pl-2\">Các phiên khoa học</span><svg class=\"w-3 h-3 text-black\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path d=\"M4 4l12 6-12 6z\"></path></svg></label></li>\n                    <li><label for=\"mica-tab-4\" class=\"py-3 px-4 cursor-pointer flex justify-between items-center transition-colors text-gray-700 hover:bg-gray-50 border-b border-dashed border-gray-400\"><span class=\"text-[15px] pl-2\">Ca lâm sàng trực tiếp</span><svg class=\"w-3 h-3 text-black\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path d=\"M4 4l12 6-12 6z\"></path></svg></label></li>\n                    <li><label for=\"mica-tab-5\" class=\"py-3 px-4 cursor-pointer flex justify-between items-center transition-colors text-gray-700 hover:bg-gray-50 border-b border-dashed border-gray-400\"><span class=\"text-[15px] pl-2\">Mẫu Slide</span><svg class=\"w-3 h-3 text-black\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path d=\"M4 4l12 6-12 6z\"></path></svg></label></li>\n                    <li><label for=\"mica-tab-6\" class=\"py-3 px-4 cursor-pointer flex justify-between items-center transition-colors text-gray-700 hover:bg-gray-50 border-b border-dashed border-gray-400\"><span class=\"text-[15px] pl-2\">Tải chương trình</span><svg class=\"w-3 h-3 text-black\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path d=\"M4 4l12 6-12 6z\"></path></svg></label></li>\n                    <li><label for=\"mica-tab-7\" class=\"py-3 px-4 cursor-pointer flex justify-between items-center transition-colors text-gray-700 hover:bg-gray-50 border-b border-dashed border-gray-400\"><span class=\"text-[15px] pl-2\">Tải tài liệu</span><svg class=\"w-3 h-3 text-black\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path d=\"M4 4l12 6-12 6z\"></path></svg></label></li>\n                </ul>\n            </nav>\n        </aside>\n\n        <!-- Nội dung -->\n        <main class=\"flex-1 bg-[#f4f3f8] overflow-y-auto\">\n            \n            <!-- TAB 1: Chương trình tổng quan -->\n            <div id=\"mica-content-1\" class=\"mica-panel\">\n                <div class=\"ribbon-title\">Chương trình tổng quan</div>\n                <div class=\"px-6 pb-10\">\n                    <div class=\"bg-white shadow-md border border-gray-200\">\n                        <div class=\"overflow-x-auto w-full\">\n                            <table class=\"w-full text-sm min-w-[1000px]\">\n                                <thead>\n                                    <tr class=\"text-center font-bold text-gray-700\">\n                                        <th class=\"w-[10%] bg-[#cbd5e1] py-3\">Phiên</th>\n                                        <th class=\"w-[25%] bg-[#fed7aa] py-3\">Hội Trường Cần Thơ</th>\n                                        <th class=\"w-[25%] bg-[#fef08a] py-3\">Hội Trường Hậu Giang</th>\n                                        <th class=\"w-[25%] bg-[#bbf7d0] py-3\">Hội Trường Sóc Trăng</th>\n                                        <th class=\"w-[15%] bg-[#bfdbfe] py-3\">Coffee Corner</th>\n                                    </tr>\n                                </thead>\n                                <tbody class=\"bg-white\">\n                                    <tr class=\"bg-[#1e3a8a] text-white\">\n                                        <td colspan=\"5\" class=\"py-2 text-center text-base font-bold\">Thứ sáu, ngày 15/5/2026 (13-17h)</td>\n                                    </tr>\n                                    <tr class=\"hover:bg-gray-50\">\n                                        <td class=\"text-center font-bold align-middle bg-gray-100\">-</td>\n                                        <td><div class=\"font-bold\">Báo cáo khoa học</div><div class=\"text-gray-600 text-xs\">(Tim mạch)</div></td>\n                                        <td><div class=\"font-bold\">Báo cáo khoa học</div><div class=\"text-gray-600 text-xs\">(Tim mạch can thiệp)</div></td>\n                                        <td class=\"bg-gray-50\"></td>\n                                        <td class=\"bg-gray-50\"></td>\n                                    </tr>\n                                    <tr class=\"bg-[#b48600] text-white mt-4\">\n                                        <td colspan=\"5\" class=\"py-2 text-center text-base font-bold\">Thứ bảy, ngày 16/5/2026 (7-17h)</td>\n                                    </tr>\n                                    <tr class=\"hover:bg-gray-50\">\n                                        <td class=\"text-center font-bold align-middle bg-gray-100\">Phiên 1</td>\n                                        <td>Quản lý toàn diện Hội chứng vành cấp</td>\n                                        <td>Cập nhật vai trò hình ảnh học nội mạch trong PCI: IVUS, IVUS-NIRS và OCT</td>\n                                        <td>Live case in a box 2: Calcified lesions</td>\n                                        <td>Xử trí biến chứng trong PCI phức tạp</td>\n                                    </tr>\n                                    <tr class=\"hover:bg-gray-50\">\n                                        <td class=\"text-center font-bold align-middle bg-gray-100\">Phiên 2</td>\n                                        <td>Chiến lược điều trị toàn diện Hội chứng vành mạn</td>\n                                        <td>Tiếp cận toàn diện tổn thương MV vôi hóa nặng: CB, Rota, IVL shock wave, IVL- mechanical</td>\n                                        <td>Live case in a box 1: Image-guided Complex PCI</td>\n                                        <td class=\"bg-gray-50\"></td>\n                                    </tr>\n                                    <tr class=\"hover:bg-gray-50\">\n                                        <td class=\"text-center font-bold align-middle bg-gray-100\">Phiên 3</td>\n                                        <td>Điều trị toàn diện suy tim theo hướng tiếp cận mới</td>\n                                        <td>Kỷ nguyên bóng phủ thuốc trong can thiệp mạch vành</td>\n                                        <td>Live case: Complex PCI</td>\n                                        <td>Những ca can thiệp cho người mới bắt đầu</td>\n                                    </tr>\n                                    <tr class=\"bg-[#fff7ed] hover:bg-[#ffedd5]\">\n                                        <td class=\"font-bold text-[#c2410c] text-center align-middle\">LUNCH SYMPOSIUM</td>\n                                        <td colspan=\"4\" class=\"text-center font-bold text-[#c2410c] py-4 align-middle\">\n                                            Tiếp cận sớm trong quản lý bệnh tim - thận - chuyển hóa<br><br>\n                                            Xu hướng mới trong can thiệp tim mạch\n                                        </td>\n                                    </tr>\n                                    <tr class=\"hover:bg-gray-50\">\n                                        <td class=\"text-center font-bold align-middle bg-gray-100\">Phiên 4</td>\n                                        <td>Tim mạch - Đái tháo đường: nguy cơ tim mạch và can thiệp sớm</td>\n                                        <td>Can thiệp mạch máu ngoại biên hiện đại</td>\n                                        <td>TAVI: những điều cần cập nhật</td>\n                                        <td class=\"bg-gray-50\"></td>\n                                    </tr>\n                                    <tr class=\"hover:bg-gray-50\">\n                                        <td class=\"text-center font-bold align-middle bg-gray-100\">Phiên 5</td>\n                                        <td>Thách thức và chiến lược tối ưu hóa điều trị rung nhĩ</td>\n                                        <td>Can thiệp bệnh tim cấu trúc: xu hướng 2026</td>\n                                        <td>Can thiệp thân chung và CTO: khi nào, bằng cách nào?</td>\n                                        <td class=\"bg-gray-50\"></td>\n                                    </tr>\n                                    <tr class=\"hover:bg-gray-50\">\n                                        <td class=\"text-center font-bold align-middle bg-gray-100\">Phiên 6</td>\n                                        <td>Tăng huyết áp và yếu tố nguy cơ: tiếp cận mới?</td>\n                                        <td>Chiến lược can thiệp sang thương phân nhánh</td>\n                                        <td>Can thiệp và kiểm soát rối loạn nhịp</td>\n                                        <td class=\"bg-gray-50\"></td>\n                                    </tr>\n                                </tbody>\n                            </table>\n                        </div>\n                    </div>\n                </div>\n            </div>\n\n            <!-- TAB 2: Rỗng -->\n            <div id=\"mica-content-2\" class=\"mica-panel\">\n                <div class=\"ribbon-title\">Chương trình chi tiết</div>\n                <div class=\"px-6 flex justify-center items-center h-64\">\n                    <div class=\"bg-white px-8 py-10 rounded-lg shadow-sm border border-gray-200 text-center w-full max-w-2xl\">\n                        <h3 class=\"text-lg font-medium text-gray-900\">Nội dung đang cập nhật</h3>\n                        <p class=\"mt-1 text-gray-500\">Thông tin chi tiết cho mục \"Chương trình chi tiết\" sẽ sớm được bổ sung.</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- TAB 3: Rỗng -->\n            <div id=\"mica-content-3\" class=\"mica-panel\">\n                <div class=\"ribbon-title\">Các phiên khoa học</div>\n                <div class=\"px-6 flex justify-center items-center h-64\">\n                    <div class=\"bg-white px-8 py-10 rounded-lg shadow-sm border border-gray-200 text-center w-full max-w-2xl\">\n                        <h3 class=\"text-lg font-medium text-gray-900\">Nội dung đang cập nhật</h3>\n                        <p class=\"mt-1 text-gray-500\">Thông tin chi tiết cho mục \"Các phiên khoa học\" sẽ sớm được bổ sung.</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- TAB 4: Rỗng -->\n            <div id=\"mica-content-4\" class=\"mica-panel\">\n                <div class=\"ribbon-title\">Ca lâm sàng trực tiếp</div>\n                <div class=\"px-6 flex justify-center items-center h-64\">\n                    <div class=\"bg-white px-8 py-10 rounded-lg shadow-sm border border-gray-200 text-center w-full max-w-2xl\">\n                        <h3 class=\"text-lg font-medium text-gray-900\">Nội dung đang cập nhật</h3>\n                        <p class=\"mt-1 text-gray-500\">Thông tin chi tiết cho mục \"Ca lâm sàng trực tiếp\" sẽ sớm được bổ sung.</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- TAB 5: Rỗng -->\n            <div id=\"mica-content-5\" class=\"mica-panel\">\n                <div class=\"ribbon-title\">Mẫu Slide</div>\n                <div class=\"px-6 flex justify-center items-center h-64\">\n                    <div class=\"bg-white px-8 py-10 rounded-lg shadow-sm border border-gray-200 text-center w-full max-w-2xl\">\n                        <h3 class=\"text-lg font-medium text-gray-900\">Nội dung đang cập nhật</h3>\n                        <p class=\"mt-1 text-gray-500\">Thông tin chi tiết cho mục \"Mẫu Slide\" sẽ sớm được bổ sung.</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- TAB 6: Rỗng -->\n            <div id=\"mica-content-6\" class=\"mica-panel\">\n                <div class=\"ribbon-title\">Tải chương trình</div>\n                <div class=\"px-6 flex justify-center items-center h-64\">\n                    <div class=\"bg-white px-8 py-10 rounded-lg shadow-sm border border-gray-200 text-center w-full max-w-2xl\">\n                        <h3 class=\"text-lg font-medium text-gray-900\">Nội dung đang cập nhật</h3>\n                        <p class=\"mt-1 text-gray-500\">Thông tin chi tiết cho mục \"Tải chương trình\" sẽ sớm được bổ sung.</p>\n                    </div>\n                </div>\n            </div>\n\n            <!-- TAB 7: Rỗng -->\n            <div id=\"mica-content-7\" class=\"mica-panel\">\n                <div class=\"ribbon-title\">Tải tài liệu</div>\n                <div class=\"px-6 flex justify-center items-center h-64\">\n                    <div class=\"bg-white px-8 py-10 rounded-lg shadow-sm border border-gray-200 text-center w-full max-w-2xl\">\n                        <h3 class=\"text-lg font-medium text-gray-900\">Nội dung đang cập nhật</h3>\n                        <p class=\"mt-1 text-gray-500\">Thông tin chi tiết cho mục \"Tải tài liệu\" sẽ sớm được bổ sung.</p>\n                    </div>\n                </div>\n            </div>\n\n        </main>\n    </div>\n</div>"
}