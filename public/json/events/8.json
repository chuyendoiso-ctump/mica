{
    "title": "Hội nghị khoa học Tim mạch Can thiệp Mekong lần II – 2026",
    "date": "2026-05-16",
    "location": "Cần Thơ",
    "content": "<style>\n    /* CSS Tối ưu Responsive & Tự động giãn chiều cao */\n    #mica-program-component {\n        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;\n        display: flex;\n        flex-direction: column;\n        width: 100%;\n        max-width: 80rem;\n        background-color: #f3f4f6;\n        color: #1f2937;\n        border: 1px solid #d1d5db;\n        border-radius: 0.75rem;\n        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);\n        margin: 0 auto;\n    }\n    .mica-header {\n        background-color: #3b82f6;\n        color: white;\n        padding: 1rem;\n        border-top-left-radius: 0.75rem;\n        border-top-right-radius: 0.75rem;\n    }\n    .mica-header h2 {\n        font-size: 1.25rem;\n        font-weight: 500;\n        margin: 0;\n    }\n    @media (min-width: 768px) {\n        .mica-header h2 { font-size: 1.5rem; padding-left: 1rem; }\n    }\n    .mica-body {\n        display: flex;\n        flex-direction: column;\n    }\n    @media (min-width: 768px) {\n        .mica-body { flex-direction: row; }\n    }\n    .mica-sidebar {\n        background-color: white;\n        flex-shrink: 0;\n        border-bottom: 1px solid #d1d5db;\n    }\n    @media (min-width: 768px) {\n        .mica-sidebar {\n            width: 16rem;\n            border-right: 1px solid #d1d5db;\n            border-bottom: none;\n        }\n    }\n    .mica-nav {\n        width: 100%;\n    }\n    .mica-menu {\n        list-style: none;\n        padding: 0;\n        margin: 0;\n        display: flex;\n        overflow-x: auto;\n        -webkit-overflow-scrolling: touch;\n        white-space: nowrap;\n    }\n    .mica-menu::-webkit-scrollbar { height: 4px; }\n    .mica-menu::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 4px; }\n    @media (min-width: 768px) {\n        .mica-menu {\n            flex-direction: column;\n            padding: 1.5rem 0 1.5rem 0;\n            white-space: normal;\n            overflow-x: visible;\n        }\n    }\n    .mica-menu li {\n        padding: 0.75rem 1rem;\n        cursor: pointer;\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        color: #374151;\n        border-right: 1px solid #e5e7eb;\n        border-bottom: 3px solid transparent;\n        transition: all 0.2s;\n    }\n    @media (min-width: 768px) {\n        .mica-menu li {\n            border-right: none;\n            border-bottom: 1px dashed #9ca3af;\n            border-left: 4px solid transparent;\n        }\n    }\n    .mica-menu li:hover { background-color: #f9fafb; }\n    .mica-menu li.menu-active {\n        font-weight: bold;\n        color: #1f2937;\n        background: linear-gradient(180deg, #dbeafe 0%, transparent 100%);\n        border-bottom-color: #be185d;\n    }\n    @media (min-width: 768px) {\n        .mica-menu li.menu-active {\n            background: linear-gradient(90deg, #dbeafe 0%, transparent 100%);\n            border-bottom-color: #d1d5db;\n            border-left-color: #be185d;\n        }\n    }\n    .mica-menu li span { font-size: 15px; }\n    @media (min-width: 768px) { .mica-menu li span { padding-left: 0.5rem; } }\n    .mica-menu li svg {\n        width: 12px;\n        height: 12px;\n        fill: currentColor;\n        margin-left: 12px;\n        display: none;\n    }\n    @media (min-width: 768px) {\n        .mica-menu li svg { display: block; }\n    }\n    .mica-main {\n        flex: 1;\n        background-color: #f4f3f8;\n        padding-bottom: 2rem;\n        border-bottom-left-radius: 0.75rem;\n        border-bottom-right-radius: 0.75rem;\n    }\n    .mica-main .ribbon-title {\n        position: relative;\n        background: linear-gradient(to right, #1e3a8a, #be185d);\n        color: white;\n        padding: 10px 20px;\n        border-radius: 16px 16px 16px 0;\n        display: inline-block;\n        font-size: 1.125rem;\n        font-weight: 500;\n        margin: 16px 0 16px 16px;\n        box-shadow: 2px 2px 5px rgba(0,0,0,0.2);\n    }\n    @media (min-width: 768px) {\n        .mica-main .ribbon-title {\n            padding: 12px 24px;\n            font-size: 1.25rem;\n            margin: 24px 0 24px 16px;\n        }\n    }\n    .mica-main .ribbon-title::before {\n        content: '';\n        position: absolute;\n        bottom: -10px;\n        left: 0;\n        border-width: 10px 10px 0 0;\n        border-style: solid;\n        border-color: #1e3a8a transparent transparent transparent;\n    }\n    .mica-content-wrapper { padding: 0 1rem; }\n    @media (min-width: 768px) {\n        .mica-content-wrapper { padding: 0 1.5rem; }\n    }\n    .mica-table-card {\n        background-color: white;\n        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);\n        border: 1px solid #e5e7eb;\n        border-radius: 0.5rem;\n        overflow: hidden;\n    }\n    .mica-table-responsive {\n        overflow-x: auto;\n        width: 100%;\n        -webkit-overflow-scrolling: touch;\n    }\n    .mica-main table {\n        border-collapse: collapse;\n        width: 100%;\n        min-width: 800px;\n        font-size: 13px;\n    }\n    @media (min-width: 768px) {\n        .mica-main table { min-width: 1000px; font-size: 14px; }\n    }\n    .mica-main th, .mica-main td {\n        border: 1px solid #e5e7eb;\n        padding: 10px;\n        vertical-align: top;\n    }\n    @media (min-width: 768px) {\n        .mica-main th, .mica-main td { padding: 12px; }\n    }\n    .mica-empty-container {\n        padding: 0 1.5rem;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        min-height: 16rem;\n    }\n    .mica-empty-box {\n        background-color: white;\n        padding: 2.5rem 1rem;\n        border-radius: 0.5rem;\n        box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);\n        border: 1px solid #e5e7eb;\n        text-align: center;\n        width: 100%;\n        max-width: 42rem;\n    }\n    .mica-empty-box h3 {\n        font-size: 1.125rem;\n        font-weight: 500;\n        color: #111827;\n        margin: 0 0 0.25rem 0;\n    }\n    .mica-empty-box p {\n        margin: 0;\n        color: #6b7280;\n        font-size: 0.875rem;\n    }\n    .mica-empty-icon {\n        margin: 0 auto 1rem auto;\n        width: 3rem;\n        height: 3rem;\n        color: #9ca3af;\n    }\n</style>\n\n<div id=\"mica-program-component\">\n    <header class=\"mica-header\">\n        <h2>Chương trình Khoa học</h2>\n    </header>\n    <div class=\"mica-body\">\n        <aside class=\"mica-sidebar\">\n            <nav class=\"mica-nav\">\n                <ul class=\"mica-menu\" id=\"mica-menu-list\"></ul>\n            </nav>\n        </aside>\n        <main class=\"mica-main\" id=\"mica-main-content\">\n        </main>\n    </div>\n</div>"
}